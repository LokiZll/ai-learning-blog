---
import { CATEGORIES } from '../lib/categories';
import ThemeToggle from './ThemeToggle.tsx';
import Search from './Search.tsx';

const currentPath = Astro.url.pathname;
---

<header class="border-b border-stone-200/80 dark:border-stone-800/80 bg-stone-50/90 dark:bg-stone-950/90 backdrop-blur-md sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-indigo-600 dark:text-indigo-400 hover:opacity-80 transition-opacity">
      📖 AI 学习博客
    </a>

    <div class="hidden md:flex items-center gap-6">
      <a
        href="/"
        class:list={[
          'relative text-sm py-5 transition-colors',
          currentPath === '/'
            ? 'text-indigo-600 dark:text-indigo-400 font-medium after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-indigo-600 dark:after:bg-indigo-400 after:rounded-full'
            : 'text-stone-600 dark:text-stone-400 hover:text-indigo-600 dark:hover:text-indigo-400',
        ]}
      >
        首页
      </a>
      {Object.entries(CATEGORIES).map(([key, { label, icon }]) => (
        <a
          href={`/category/${key}`}
          class:list={[
            'relative text-sm py-5 transition-colors',
            currentPath === `/category/${key}`
              ? 'text-indigo-600 dark:text-indigo-400 font-medium after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-indigo-600 dark:after:bg-indigo-400 after:rounded-full'
              : 'text-stone-600 dark:text-stone-400 hover:text-indigo-600 dark:hover:text-indigo-400',
          ]}
        >
          {icon} {label}
        </a>
      ))}
      <a
        href="/tags"
        class:list={[
          'relative text-sm py-5 transition-colors',
          currentPath === '/tags'
            ? 'text-indigo-600 dark:text-indigo-400 font-medium after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-indigo-600 dark:after:bg-indigo-400 after:rounded-full'
            : 'text-stone-600 dark:text-stone-400 hover:text-indigo-600 dark:hover:text-indigo-400',
        ]}
      >
        标签
      </a>
    </div>

    <div class="flex items-center gap-3">
      <Search client:load />
      <ThemeToggle client:load />

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg hover:bg-stone-100 dark:hover:bg-stone-800 transition-colors"
        aria-label="打开菜单"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-950">
    <div class="px-4 py-3 space-y-2">
      <a href="/" class="block py-2 text-sm hover:text-indigo-600 dark:hover:text-indigo-400">首页</a>
      {Object.entries(CATEGORIES).map(([key, { label, icon }]) => (
        <a href={`/category/${key}`} class="block py-2 text-sm hover:text-indigo-600 dark:hover:text-indigo-400">
          {icon} {label}
        </a>
      ))}
      <a href="/tags" class="block py-2 text-sm hover:text-indigo-600 dark:hover:text-indigo-400">标签</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
