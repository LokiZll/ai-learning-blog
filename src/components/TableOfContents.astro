---
interface HeadingItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: HeadingItem[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="sticky top-24">
    <h3 class="text-sm font-semibold mb-3 text-stone-500 dark:text-stone-400 uppercase tracking-wider">目录</h3>
    <ul class="space-y-1.5 text-sm border-l-2 border-stone-200 dark:border-stone-800">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block py-0.5 text-stone-500 dark:text-stone-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors toc-link',
              heading.depth === 2 ? 'pl-3' : 'pl-6',
            ]}
            data-slug={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  const links = document.querySelectorAll('.toc-link');
  const headings = Array.from(links).map((link) => {
    const slug = link.getAttribute('data-slug');
    return slug ? document.getElementById(slug) : null;
  }).filter(Boolean) as HTMLElement[];

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          links.forEach((link) => {
            link.classList.remove('text-indigo-600', 'dark:text-indigo-400', 'font-medium');
            link.classList.add('text-stone-500', 'dark:text-stone-400');
          });
          const activeLink = document.querySelector(`.toc-link[data-slug="${entry.target.id}"]`);
          if (activeLink) {
            activeLink.classList.add('text-indigo-600', 'dark:text-indigo-400', 'font-medium');
            activeLink.classList.remove('text-stone-500', 'dark:text-stone-400');
          }
        }
      }
    },
    { rootMargin: '-80px 0px -70% 0px' }
  );

  headings.forEach((heading) => observer.observe(heading));
</script>
