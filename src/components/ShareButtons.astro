    rel="noopener"
    class="p-2 rounded-lg hover:bg-stone-100 dark:hover:bg-stone-800 transition-colors text-stone-500 dark:text-stone-400 hover:text-indigo-600 dark:hover:text-indigo-400"
    title="分享到QQ"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.411 0-8-3.589-8-8s3.589-8 8-8 8 3.589 8 8-3.589 8-8 8zm-2-13h4v4h-4V7zm-4 2h4v4H6V9zm8 0h4v4h-4V9zm-2 6h4v4h-4v-4z"/>
