---
interface Props {
  prev?: { id: string; title: string } | null;
  next?: { id: string; title: string } | null;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="mt-12 pt-6 border-t border-stone-200 dark:border-stone-800 grid grid-cols-2 gap-4">
    <div>
      {prev && (
        <a href={`/blog/${prev.id}`} class="group block p-4 rounded-xl hover:bg-stone-100 dark:hover:bg-stone-800/50 transition-colors">
          <span class="text-sm text-stone-500 dark:text-stone-400">← 上一篇</span>
          <p class="font-medium group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
            {prev.title}
          </p>
        </a>
      )}
    </div>
    <div class="text-right">
      {next && (
        <a href={`/blog/${next.id}`} class="group block p-4 rounded-xl hover:bg-stone-100 dark:hover:bg-stone-800/50 transition-colors">
          <span class="text-sm text-stone-500 dark:text-stone-400">下一篇 →</span>
          <p class="font-medium group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
            {next.title}
          </p>
        </a>
      )}
    </div>
  </nav>
)}
