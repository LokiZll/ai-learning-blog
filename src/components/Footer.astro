---
import { CATEGORIES } from '../lib/categories';
const year = new Date().getFullYear();
---

<footer class="bg-zinc-50 dark:bg-zinc-900 mt-16">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
      <div>
        <h3 class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider mb-3">分类</h3>
        <div class="flex flex-col gap-2">
          {Object.entries(CATEGORIES).map(([key, cat]) => (
            <a
              href={`/category/${key}`}
              class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              {cat.label}
            </a>
          ))}
        </div>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider mb-3">导航</h3>
        <div class="flex flex-col gap-2">
          <a href="/series" class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">文章系列</a>
          <a href="/tags" class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">标签</a>
          <a href="/archive" class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">归档</a>
          <a href="/about" class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">关于</a>
        </div>
      </div>
    </div>
    <div class="border-t border-zinc-200 dark:border-zinc-800 pt-6 text-center text-sm text-zinc-400 dark:text-zinc-500">
      <p>&copy; {year} AI 学习博客. Powered by <a href="https://astro.build" class="hover:text-blue-600 dark:hover:text-blue-400 underline" target="_blank" rel="noopener">Astro</a> | <a href="/rss.xml" class="hover:text-blue-600 dark:hover:text-blue-400 underline">RSS 订阅</a></p>
      <p class="mt-2"><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" class="hover:text-blue-600 dark:hover:text-blue-400 underline">赣ICP备2026000372号-2</a></p>
    </div>
  </div>
</footer>
