---
import { getCollection } from 'astro:content';

interface Props {
  series: string;
  seriesOrder: number;
  currentId: string;
}

const { series, seriesOrder, currentId } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.series === series);
const seriesPosts = allPosts.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
---

<nav class="mb-8 rounded-xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 p-5">
  <h3 class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 mb-3">
    {series}
  </h3>
  <ol class="space-y-1.5 text-sm">
    {seriesPosts.map((post, i) => (
      <li class="flex items-baseline gap-2">
        <span class="text-stone-400 dark:text-stone-500 select-none">{i + 1}.</span>
        {post.id === currentId ? (
          <span class="font-medium text-stone-900 dark:text-stone-100">{post.data.title}</span>
        ) : (
          <a
            href={`/blog/${post.id}`}
            class="text-stone-600 dark:text-stone-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
          >
            {post.data.title}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
