---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ArticleNav from '../components/ArticleNav.astro';
import TagList from '../components/TagList.astro';
import SeriesNav from '../components/SeriesNav.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ShareButtons from '../components/ShareButtons.astro';
import CommentSection from '../components/CommentSection.astro';
import BackToTop from '../components/BackToTop.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import LikeButton from '../components/LikeButton.astro';
import { CATEGORIES, type Category } from '../lib/categories';

interface Props {
  title: string;
  description: string;
  category: Category;
  tags: string[];
  date: Date;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: { id: string; title: string } | null;
  nextPost?: { id: string; title: string } | null;
  series?: string;
  seriesOrder?: number;
  currentId?: string;
  readingTime?: number;
  wordCount?: number;
  updatedDate?: Date;
}

const { title, description, category, tags, date, headings, prevPost, nextPost, series, seriesOrder, currentId, readingTime, wordCount, updatedDate } = Astro.props;
const categoryInfo = CATEGORIES[category];
const formattedDate = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdatedDate = updatedDate?.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const articleUrl = Astro.url.href;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString(),
  url: articleUrl,
  author: { '@type': 'Person', name: 'AI 学习博客' },
  publisher: { '@type': 'Organization', name: 'AI 学习博客' },
});
---

<BaseLayout title={title} description={description} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>
  <Header slot="header" />

  <div id="reading-progress" class="reading-progress" style="width: 0%"></div>

  <article class="relative">
    <!-- Hero Section -->
    <header class="hero-section relative overflow-hidden">
      <!-- 装饰性背景 -->
      <div class="hero-pattern absolute inset-0 opacity-50"></div>
      <div class="hero-gradient absolute inset-0"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
        <!-- 元信息卡片 -->
        <div class="flex flex-wrap items-center gap-3 mb-6 animate-fade-in-up">
          <a
            href={`/category/${category}`}
            class:list={[
              'px-3 py-1.5 rounded-full text-sm font-medium transition-all duration-300',
              categoryInfo.color.badge,
              categoryInfo.color.badgeHover,
              'hover:scale-105'
            ]}
          >
            <i class={`${categoryInfo.icon} mr-1.5`}></i>
            {categoryInfo.label}
          </a>
          <span class="meta-divider">|</span>
          <time datetime={date.toISOString()} class="meta-item">
            <i class="far fa-calendar-alt mr-1.5"></i>
            {formattedDate}
          </time>
          {formattedUpdatedDate && (
            <>
              <span class="meta-divider">|</span>
              <span class="meta-item">
                <i class="fas fa-sync-alt mr-1.5"></i>
                更新于 {formattedUpdatedDate}
              </span>
            </>
          )}
          {readingTime && (
            <>
              <span class="meta-divider">|</span>
              <span class="meta-item">
                <i class="far fa-clock mr-1.5"></i>
                约 {readingTime} 分钟
              </span>
            </>
          )}
          {wordCount && (
            <>
              <span class="meta-divider">|</span>
              <span class="meta-item">
                <i class="far fa-file-word mr-1.5"></i>
                {wordCount.toLocaleString()} 字
              </span>
            </>
          )}
        </div>

        <!-- 标题 -->
        <h1 class="hero-title text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 animate-fade-in-up delay-1">
          {title}
        </h1>

        <!-- 描述 -->
        <p class="hero-description text-lg sm:text-xl mb-8 max-w-2xl animate-fade-in-up delay-2">
          {description}
        </p>

        <!-- 标签和点赞 -->
        <div class="flex flex-wrap items-center gap-4 animate-fade-in-up delay-3">
          <TagList tags={tags} />
          {currentId && <LikeButton slug={currentId} />}
        </div>
      </div>

      <!-- 底部装饰 -->
      <div class="hero-decoration">
        <svg class="w-full h-12" viewBox="0 0 1440 48" preserveAspectRatio="none">
          <path fill="currentColor" class="dark:fill-zinc-900 fill-white" d="M0,24 C480,48 960,48 1440,24 L1440,48 L0,48 Z"></path>
        </svg>
      </div>
    </header>

    {series && currentId && seriesOrder != null && (
      <SeriesNav series={series} seriesOrder={seriesOrder} currentId={currentId} />
    )}

    <div class="lg:grid lg:grid-cols-[1fr_240px] lg:gap-10">
      {headings.filter((h) => h.depth >= 2 && h.depth <= 3).length > 0 && (
        <div class="lg:hidden mb-6">
          <button
            id="mobile-toc-toggle"
            class="w-full flex items-center justify-between px-4 py-3 rounded-xl bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 text-sm font-medium shadow-sm hover:shadow-md transition-all duration-300"
          >
            <span class="flex items-center">
              <i class="fas fa-list-ul mr-2 text-blue-500"></i>
              目录
            </span>
            <svg id="mobile-toc-arrow" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <nav id="mobile-toc-list" class="hidden mt-2 px-4 py-3 rounded-xl bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700">
            <ul class="space-y-1 text-sm">
              {headings.filter((h) => h.depth >= 2 && h.depth <= 3).map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    class:list={[
                      'block py-2 px-3 rounded-lg text-zinc-600 dark:text-zinc-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-200',
                      heading.depth === 2 ? 'pl-2' : 'pl-5',
                    ]}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      )}

      <div class="prose dark:prose-invert max-w-none prose-headings:scroll-mt-20" data-pagefind-body>
        <slot />
      </div>

      {headings.length > 0 && (
        <aside class="hidden lg:block">
          <TableOfContents headings={headings} />
        </aside>
      )}
    </div>

    {currentId && (
      <RelatedArticles currentId={currentId} category={category} tags={tags} />
    )}

    <div class="mt-8 pt-6 border-t border-zinc-200 dark:border-zinc-800">
      <ShareButtons title={title} url={articleUrl} />
    </div>

    <ArticleNav prev={prevPost} next={nextPost} />

    {currentId && <CommentSection slug={currentId} />}
  </article>

  <BackToTop />
  <ImageLightbox />

  <Footer slot="footer" />
</BaseLayout>

<script>
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      if (docHeight > 0) {
        bar.style.width = `${Math.min((window.scrollY / docHeight) * 100, 100)}%`;
      }
    });
  }
</script>

<script>
  document.querySelectorAll('article pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'code-copy-btn';
    btn.textContent = '复制';
    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      if (code) {
        const text = code.textContent || '';
        // 使用兼容的复制方式，支持 HTTP 环境
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(text).then(() => {
            btn.textContent = '已复制';
            setTimeout(() => { btn.textContent = '复制'; }, 2000);
          }).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
        function fallbackCopy(copyText) {
          const textarea = document.createElement('textarea');
          textarea.value = copyText;
          textarea.style.position = 'fixed';
          textarea.style.left = '-9999px';
          document.body.appendChild(textarea);
          textarea.select();
          try {
            document.execCommand('copy');
            btn.textContent = '已复制';
            setTimeout(() => { btn.textContent = '复制'; }, 2000);
          } catch (e) {
            btn.textContent = '复制失败';
            setTimeout(() => { btn.textContent = '复制'; }, 2000);
          }
          document.body.removeChild(textarea);
        }
      }
    });
    pre.appendChild(btn);
  });
</script>

<script>
  const tocToggle = document.getElementById('mobile-toc-toggle');
  const tocList = document.getElementById('mobile-toc-list');
  const tocArrow = document.getElementById('mobile-toc-arrow');
  if (tocToggle && tocList && tocArrow) {
    tocToggle.addEventListener('click', () => {
      tocList.classList.toggle('hidden');
      tocArrow.classList.toggle('rotate-180');
    });
    tocList.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        tocList.classList.add('hidden');
        tocArrow.classList.remove('rotate-180');
      });
    });
  }
</script>

<script>
  // Mermaid 图表初始化
  async function initMermaid() {
    const mermaidElements = document.querySelectorAll('.language-mermaid, .mermaid');
    if (mermaidElements.length === 0) return;

    // 动态加载 Mermaid
    if (typeof mermaid === 'undefined') {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/mermaid@latest/dist/mermaid.min.js';
      script.onload = () => renderMermaid();
      document.head.appendChild(script);
    } else {
      renderMermaid();
    }
  }

  function renderMermaid() {
    if (typeof mermaid === 'undefined') return;

    mermaid.initialize({
      startOnLoad: false,
      theme: window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'default',
      securityLevel: 'loose',
      flowchart: {
        useMaxWidth: true,
        htmlLabels: true,
      },
    });

    // 查找所有 mermaid 代码块
    document.querySelectorAll('pre code.language-mermaid').forEach(async (code) => {
      const pre = code.parentElement;
      const graphDefinition = code.textContent || '';

      const div = document.createElement('div');
      div.className = 'mermaid';

      try {
        const { svg } = await mermaid.render(`mermaid-${Math.random().toString(36).substr(2, 9)}`, graphDefinition);
        div.innerHTML = svg;
        pre?.replaceWith(div);
      } catch (e) {
        console.error('Mermaid render error:', e);
        div.innerHTML = `<pre class="text-red-500">${e.message}</pre>`;
        pre?.replaceWith(div);
      }
    });
  }

  // 页面加载完成后初始化
  initMermaid();

  // 监听主题变化
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    initMermaid();
  });
</script>
