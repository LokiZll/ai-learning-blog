---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ArticleNav from '../components/ArticleNav.astro';
import TagList from '../components/TagList.astro';
import SeriesNav from '../components/SeriesNav.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ShareButtons from '../components/ShareButtons.astro';
import Giscus from '../components/Giscus.astro';
import { CATEGORIES, type Category } from '../lib/categories';

interface Props {
  title: string;
  description: string;
  category: Category;
  tags: string[];
  date: Date;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: { id: string; title: string } | null;
  nextPost?: { id: string; title: string } | null;
  series?: string;
  seriesOrder?: number;
  currentId?: string;
  readingTime?: number;
  updatedDate?: Date;
}

const { title, description, category, tags, date, headings, prevPost, nextPost, series, seriesOrder, currentId, readingTime, updatedDate } = Astro.props;
const categoryInfo = CATEGORIES[category];
const formattedDate = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdatedDate = updatedDate?.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const articleUrl = Astro.url.href;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString(),
  url: articleUrl,
  author: { '@type': 'Person', name: 'AI 学习博客' },
  publisher: { '@type': 'Organization', name: 'AI 学习博客' },
});
---

<BaseLayout title={title} description={description} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>
  <Header slot="header" />

  <div id="reading-progress" class="reading-progress" style="width: 0%"></div>

  <article class="relative">
    <header class="mb-8 pb-6 border-b border-stone-200 dark:border-stone-800 relative">
      <div class={`absolute left-0 top-0 bottom-0 w-1 rounded-full ${categoryInfo.color.accent}`}></div>
      <div class="pl-5">
        <div class="flex items-center gap-3 mb-3 text-sm">
          <a
            href={`/category/${category}`}
            class:list={[
              'px-2.5 py-0.5 rounded-full transition-colors',
              categoryInfo.color.badge,
              categoryInfo.color.badgeHover,
            ]}
          >
            {categoryInfo.icon} {categoryInfo.label}
          </a>
          <time datetime={date.toISOString()} class="text-stone-500 dark:text-stone-400">
            {formattedDate}
          </time>
          {formattedUpdatedDate && (
            <>
              <span class="text-stone-400 dark:text-stone-500">·</span>
              <span class="text-stone-500 dark:text-stone-400">更新于 {formattedUpdatedDate}</span>
            </>
          )}
          {readingTime && (
            <span class="text-stone-400 dark:text-stone-500">·</span>
            <span class="text-stone-500 dark:text-stone-400">约 {readingTime} 分钟</span>
          )}
        </div>
        <h1 class="text-3xl font-bold mb-4 text-stone-900 dark:text-stone-50">{title}</h1>
        <p class="text-stone-600 dark:text-stone-400 text-lg">{description}</p>
        <div class="mt-4">
          <TagList tags={tags} />
        </div>
      </div>
    </header>

    {series && currentId && seriesOrder != null && (
      <SeriesNav series={series} seriesOrder={seriesOrder} currentId={currentId} />
    )}

    <div class="lg:grid lg:grid-cols-[1fr_200px] lg:gap-10">
      {headings.filter((h) => h.depth >= 2 && h.depth <= 3).length > 0 && (
        <div class="lg:hidden mb-6">
          <button
            id="mobile-toc-toggle"
            class="w-full flex items-center justify-between px-4 py-2.5 rounded-lg bg-stone-100 dark:bg-stone-800 text-stone-700 dark:text-stone-300 text-sm font-medium"
          >
            <span>目录</span>
            <svg id="mobile-toc-arrow" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <nav id="mobile-toc-list" class="hidden mt-2 px-4 py-3 rounded-lg bg-stone-100 dark:bg-stone-800">
            <ul class="space-y-1.5 text-sm">
              {headings.filter((h) => h.depth >= 2 && h.depth <= 3).map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    class:list={[
                      'block py-0.5 text-stone-600 dark:text-stone-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors',
                      heading.depth === 2 ? 'pl-0' : 'pl-4',
                    ]}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      )}

      <div class="prose dark:prose-invert max-w-none prose-headings:scroll-mt-20" data-pagefind-body>
        <slot />
      </div>

      {headings.length > 0 && (
        <aside class="hidden lg:block">
          <TableOfContents headings={headings} />
        </aside>
      )}
    </div>

    {currentId && (
      <RelatedArticles currentId={currentId} category={category} tags={tags} />
    )}

    <div class="mt-8 pt-6 border-t border-stone-200 dark:border-stone-800">
      <ShareButtons title={title} url={articleUrl} />
    </div>

    <ArticleNav prev={prevPost} next={nextPost} />

    <Giscus term={title} />
  </article>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      if (docHeight > 0) {
        bar.style.width = `${Math.min((window.scrollY / docHeight) * 100, 100)}%`;
      }
    });
  }
</script>

<script>
  document.querySelectorAll('article pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'code-copy-btn';
    btn.textContent = '复制';
    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      if (code) {
        navigator.clipboard.writeText(code.textContent || '').then(() => {
          btn.textContent = '已复制';
          setTimeout(() => { btn.textContent = '复制'; }, 2000);
        });
      }
    });
    pre.appendChild(btn);
  });
</script>

<script>
  const tocToggle = document.getElementById('mobile-toc-toggle');
  const tocList = document.getElementById('mobile-toc-list');
  const tocArrow = document.getElementById('mobile-toc-arrow');
  if (tocToggle && tocList && tocArrow) {
    tocToggle.addEventListener('click', () => {
      tocList.classList.toggle('hidden');
      tocArrow.classList.toggle('rotate-180');
    });
    tocList.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        tocList.classList.add('hidden');
        tocArrow.classList.remove('rotate-180');
      });
    });
  }
</script>
