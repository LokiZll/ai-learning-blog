---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="页面未找到">
  <Header slot="header" />

  <div class="flex flex-col items-center justify-center py-24 text-center">
    <span class="text-6xl font-bold text-indigo-600 dark:text-indigo-400">404</span>
    <h1 class="text-2xl font-bold text-stone-900 dark:text-stone-50 mt-4">页面未找到</h1>
    <p class="text-stone-600 dark:text-stone-400 mt-2 max-w-md">
      抱歉，您访问的页面不存在或已被移动。
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 px-6 py-2.5 rounded-lg bg-indigo-600 dark:bg-indigo-500 text-white font-medium hover:bg-indigo-700 dark:hover:bg-indigo-600 transition-colors"
    >
      返回首页
    </a>
  </div>

  <Footer slot="footer" />
</BaseLayout>
