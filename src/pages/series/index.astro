---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getSeriesWithPosts } from '../../lib/series';
import { SERIES_COLORS } from '../../lib/constants';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const seriesWithPosts = getSeriesWithPosts(posts);
---

<BaseLayout title="文章系列" description="浏览系列文章">
  <Header slot="header" />

  <section>
    <h1 class="text-2xl font-bold tracking-tight mb-1">文章系列</h1>
    <p class="text-zinc-500 dark:text-zinc-400 text-sm mb-8">共 {seriesWithPosts.length} 个系列</p>

    <div class="grid gap-4">
      {seriesWithPosts.map((s) => {
        const colors = SERIES_COLORS[s.color] || SERIES_COLORS.indigo;
        return (
          <div class="border border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden">
            <a href={`/series/${s.id}`} class:list={['block px-5 py-4 border-l-4 border-b border-b-zinc-200 dark:border-b-zinc-800 hover:opacity-90 transition-opacity', colors.border, colors.bg, colors.darkBg]}>
              <div class="flex items-center justify-between">
                <div>
                  <h2 class="text-lg font-semibold tracking-tight">{s.title}</h2>
                  <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5">{s.description}</p>
                </div>
                <span class="text-sm text-zinc-400 dark:text-zinc-500 shrink-0 ml-4">{s.postDetails.length} 篇</span>
              </div>
            </a>
            <div class="px-5 py-3">
              <div class="flex flex-wrap gap-2">
                {s.postDetails.slice(0, 6).map((post) => (
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center px-2.5 py-1 rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-300 hover:bg-blue-50 dark:hover:bg-blue-950/30 hover:text-blue-600 dark:hover:text-blue-400 transition-colors text-sm"
                  >
                    {post.title}
                  </a>
                ))}
                {s.postDetails.length > 6 && (
                  <a
                    href={`/series/${s.id}`}
                    class="inline-flex items-center px-2.5 py-1 rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-400 dark:text-zinc-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors text-sm"
                  >
                    +{s.postDetails.length - 6} 篇
                  </a>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
