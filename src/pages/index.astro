---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import { CATEGORIES } from '../lib/categories';
import { getSeriesWithPosts } from '../lib/series';
import { POSTS_PER_PAGE, SERIES_COLORS } from '../lib/constants';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const hasMore = allPosts.length > POSTS_PER_PAGE;

const categoryCounts = allPosts.reduce((acc, post) => {
  acc[post.data.category] = (acc[post.data.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const seriesWithPosts = getSeriesWithPosts(allPosts);
const topSeries = seriesWithPosts
  .sort((a, b) => b.postDetails.length - a.postDetails.length)
  .slice(0, 6);
---

<BaseLayout title="首页">
  <Header slot="header" />

  <section class="hero-pattern -mx-4 px-4 py-16 mb-10 border-b border-zinc-200 dark:border-zinc-800 relative overflow-hidden">
    <!-- 装饰性渐变 -->
    <div class="absolute inset-0 opacity-30 dark:opacity-10 pointer-events-none">
      <div class="absolute top-0 right-0 w-96 h-96 bg-gradient-to-br from-blue-500/20 to-purple-500/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-gradient-to-tr from-teal-500/20 to-blue-500/20 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-2xl relative">
      <!-- 装饰性标签 -->
      <div class="flex items-center gap-2 mb-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-50 dark:bg-blue-950/40 text-blue-600 dark:text-blue-400">
          <i class="fas fa-brain text-xs"></i>
          AI 学习
        </span>
        <span class="w-1 h-1 rounded-full bg-zinc-400"></span>
        <span class="text-xs text-zinc-500 dark:text-zinc-400">持续更新</span>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-zinc-900 dark:text-zinc-50" style="font-family: 'Noto Serif SC', serif;">
        AI 学习空间
      </h1>

      <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed mb-6">
        记录和整理 AI 学习技能笔记，构建个人知识体系。从基础概念到实战案例，一步步掌握 AI 技能。
      </p>

      <!-- 统计数据 -->
      <div class="flex items-center gap-6 text-sm">
        <div class="flex items-center gap-2 text-zinc-500 dark:text-zinc-400">
          <i class="fas fa-file-alt text-blue-500"></i>
          <span>{allPosts.length} 篇文章</span>
        </div>
        <div class="flex items-center gap-2 text-zinc-500 dark:text-zinc-400">
          <i class="fas fa-layer-group text-purple-500"></i>
          <span>{seriesWithPosts.length} 个系列</span>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-sm font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-4" style="font-family: 'Noto Sans SC', sans-serif;">学习路径</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {Object.entries(CATEGORIES).map(([key, cat]) => (
        <a
          href={`/category/${key}`}
          class="card-hover-enhanced glass-card block p-5 rounded-2xl"
        >
          <div class:list={['w-10 h-10 rounded-xl flex items-center justify-center mb-3', cat.color.bg]}>
            <span class="text-lg">{cat.icon}</span>
          </div>
          <h3 class:list={['font-semibold text-zinc-800 dark:text-zinc-100 mb-1', cat.color.text]}>{cat.label}</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400">{categoryCounts[key] || 0} 篇文章</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-sm font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-4" style="font-family: 'Noto Sans SC', sans-serif;">热门系列</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {topSeries.map((s) => {
        const colors = SERIES_COLORS[s.color] || SERIES_COLORS.indigo;
        return (
          <a href={`/series/${s.id}`} class:list={['card-hover-enhanced block p-5 rounded-2xl border border-zinc-100 dark:border-zinc-800 bg-white dark:bg-zinc-900', colors.border]}>
            <div class:list={['flex items-center gap-2 mb-2', colors.text, colors.darkText]}>
              <i class="fas fa-book-open"></i>
              <h3 class:list={['font-semibold']}>{s.title}</h3>
            </div>
            <p class="text-xs text-zinc-500 dark:text-zinc-400">{s.postDetails.length} 篇文章</p>
          </a>
        );
      })}
    </div>
    <div class="mt-4 text-center">
      <a href="/series" class="inline-flex items-center gap-1 text-sm text-blue-600 dark:text-blue-400 hover:underline">
        查看全部 {seriesWithPosts.length} 个系列 →
      </a>
    </div>
  </section>

  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-sm font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">最新文章</h2>
      <div class="flex flex-wrap gap-2" id="category-filter">
        <button data-category="all" class="filter-btn active text-xs px-3 py-1 rounded-full bg-blue-600 text-white transition-colors">全部</button>
        {Object.entries(CATEGORIES).map(([key, cat]) => (
          <button data-category={key} class="filter-btn text-xs px-3 py-1 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            {cat.label}
          </button>
        ))}
      </div>
    </div>

    {posts.length > 0 ? (
      <div class="space-y-6" id="article-list">
        {posts.map((post) => (
          <div data-category={post.data.category}>
            <ArticleCard
              id={post.id}
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              tags={post.data.tags}
              date={post.data.date}
            />
          </div>
        ))}
      </div>
    ) : (
      <p class="text-zinc-500 dark:text-zinc-400 text-center py-12">暂无文章，快来写第一篇吧！</p>
    )}

    {hasMore && (
      <div class="mt-8 text-center">
        <a
          href="/page/2"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors"
        >
          查看更多文章 ({allPosts.length - POSTS_PER_PAGE} 篇) →
        </a>
      </div>
    )}
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const articles = document.querySelectorAll('#article-list > div[data-category]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');

      buttons.forEach((b) => {
        b.classList.remove('active', 'bg-blue-600', 'text-white');
        b.classList.add('bg-zinc-100', 'dark:bg-zinc-800', 'text-zinc-600', 'dark:text-zinc-400');
      });
      btn.classList.add('active', 'bg-blue-600', 'text-white');
      btn.classList.remove('bg-zinc-100', 'dark:bg-zinc-800', 'text-zinc-600', 'dark:text-zinc-400');

      articles.forEach((article) => {
        if (cat === 'all' || article.getAttribute('data-category') === cat) {
          (article as HTMLElement).style.display = '';
        } else {
          (article as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
